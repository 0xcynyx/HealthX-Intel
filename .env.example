# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.

# ─── X API v2 ────────────────────────────────────────────────────────────────
# Your X app's OAuth2 client credentials (Developer Portal → Keys & tokens →
# "Consumer Keys" / "API Key & Secret"). The server mints an app-only Bearer
# token from these for read endpoints (user lookup, timelines, recent search,
# trends). App-only context = public reads only, no actions-as-you.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
# Optional: skip the client_credentials exchange by pasting a pre-minted
# app-only bearer. If set, it takes precedence over the key/secret above.
X_BEARER_TOKEN=
# WOEID for the trends panel. 1 = worldwide. (e.g. 23424977 = United States)
X_TRENDS_WOEID=1

# ─── Sally (A1C) MCP ─────────────────────────────────────────────────────────
# Streamable-HTTP MCP endpoint + an API key minted at https://console.a1c.io.
# Calls are metered (see per-tool pricing). Top up your console balance first.
SALLY_MCP_URL=https://sally.a1c.io/mcp
SALLY_API_KEY=
# IANA timezone used for Sally insight timing (morning/afternoon/evening).
SALLY_TIMEZONE=America/Los_Angeles

# ─── Sync ────────────────────────────────────────────────────────────────────
# Server-side cache TTL in ms. The dashboard also auto-refreshes on this
# cadence. 300000 = 5 minutes.
SYNC_INTERVAL_MS=300000
